# ── Client (Vite) environment ────────────────────────────────────────────────
# Copy to .env.local and fill in. All client vars MUST be prefixed VITE_.

# Supabase Auth. When BOTH are set, the app requires login (/login, /signup);
# when unset, the app runs in standalone mock/demo mode with no auth.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon public key>"

# Backend (the multi-tenant Fastify server in /server). Set VITE_USE_BACKEND=1
# to use the real backend instead of the in-memory mock provider.
# VITE_USE_BACKEND="1"
# VITE_API_URL="https://your-server.example.com"   # REST base ('' = same origin / dev proxy)
# VITE_WS_URL="wss://your-server.example.com"       # WebSocket base ('' = same origin)

# Authoritative-state source for the auth/team GATE + role (Step 2 cutover).
#   "supabase" (DEFAULT) — gate/role derived from Supabase business tables (today's behaviour).
#   "me"                 — gate/role derived from the backend GET /v1/me (Prisma authority);
#                          the Supabase data layer is untouched (still keys business screens).
# ⚠ PRODUCTION MUST stay "supabase" until the Supabase→Prisma data migration is completed AND
#   verified. "me" is for NON-production validation only (the two team-id spaces are disjoint).
# VITE_AUTH_SOURCE="supabase"
