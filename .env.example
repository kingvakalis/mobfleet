# ── Client (Vite) environment ────────────────────────────────────────────────
# Copy to .env.local and fill in. All client vars MUST be prefixed VITE_, and
# every variable below is read by client code via import.meta.env.

# Supabase Auth. When BOTH are set, the app requires login (/login, /signup) and
# loads the signed-in user's real team, roles, and permissions. When either is
# unset the app runs in standalone mock/demo mode with no auth (the public demo
# build) — there is no hidden third state.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon public key>"

# Public app URL used to build the password-reset redirect target: the link in the
# Supabase recovery email returns the user here at /reset-password. Falls back to
# the current browser origin when unset, so it is only needed for deployed
# environments whose origin differs from where the email is opened.
# VITE_APP_URL="https://your-app.example.com"

# Backend (the multi-tenant Fastify server in /server). Set VITE_USE_BACKEND=1 to
# route the app through the real backend instead of the in-memory mock provider.
# VITE_USE_BACKEND="1"
# VITE_API_URL="https://your-server.example.com"   # REST base ('' = same origin / dev proxy)
# VITE_WS_URL="wss://your-server.example.com"      # WebSocket base ('' = same origin)
