# ─────────────────────────────────────────────────────────────────────────────
# MobFleet STAGING env template (placeholders only — NEVER commit real secrets).
# Set these in the Railway STAGING service (backend) and the staging frontend build
# (VITE_*). Do NOT copy values from server/.env (those are LIVE secrets). Do NOT
# point any of these at the live Supabase DB / live domain / live Resend key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (Railway staging service) ──
NODE_ENV="production"
AUTH_PROVIDER="supabase"
# Dedicated STAGING Supabase project JWT secret (NOT the live one — sharing it shares the user pool).
SUPABASE_JWT_SECRET="<staging supabase jwt secret>"
# Optional but recommended (match the staging Supabase project):
AUTH_AUDIENCE="authenticated"
AUTH_ISSUER="https://<staging-ref>.supabase.co/auth/v1"

# Isolated STAGING Postgres — runtime role (DML only) and migrator role (DDL, least-privilege).
# Append ?sslmode=no-verify ONLY if the staging Postgres uses a self-signed cert (e.g. Railway TCP proxy).
DATABASE_URL="postgresql://<staging_runtime_role>:<pw>@<staging-host>:<port>/<db>"
MIGRATION_DATABASE_URL="postgresql://mobfleet_migrator:<pw>@<staging-host>:<port>/<db>"

# Staging public URLs / CORS (staging only — never the live domain, never *).
PUBLIC_SERVER_URL="https://<staging-api-host>"
APP_URL="https://<staging-spa-host>"
ALLOWED_ORIGIN="https://<staging-spa-host>"

# Mail: staging MUST use console transport (links are logged, never emailed). No live Resend key.
MAIL_TRANSPORT="console"
# RESEND_API_KEY intentionally UNSET on staging.

# PORT is injected by Railway. AUTO_PROVISION_TEAM defaults true. PROVIDER defaults simulated.
# Do NOT set: ALLOW_INSECURE_DEV_AUTH, AUTH_PROVIDER=dev, any TEST_*/SUPABASE_DB_URL.

# ── Frontend (separate staging Vercel project / build — do NOT touch prod Vercel) ──
# VITE_SUPABASE_URL="https://<staging-ref>.supabase.co"
# VITE_SUPABASE_ANON_KEY="<staging anon key>"
# VITE_USE_BACKEND="1"
# VITE_API_URL="https://<staging-api-host>"
# VITE_WS_URL="wss://<staging-api-host>"
# VITE_AUTH_SOURCE="supabase"   # stays supabase (no me-mode / no Phase 3C in this rollout)
