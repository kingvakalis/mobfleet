# Production build env — loaded by `vite build` / production mode only (NOT dev).
# In dev, vite.config.ts proxies /v1 + /ws to localhost:8787, so VITE_API_URL is
# intentionally left empty there. See .env.example for the full backend var set.

# REST API base — the deployed Fastify backend on Railway. Every API call reads
# this via import.meta.env.VITE_API_URL (http-provider, services/team,
# services/email-settings, mock-provider pairing QR).
VITE_API_URL="https://phone-farm-app-production.up.railway.app"

# Route the app through the deployed backend (otherwise it uses the in-memory
# mock provider and never hits VITE_API_URL for most calls).
VITE_USE_BACKEND="1"

# Live WebSocket feed base (telemetry, job/device updates).
VITE_WS_URL="wss://phone-farm-app-production.up.railway.app"
