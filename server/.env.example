# Local dev (SQLite file, zero external infra)
DATABASE_URL="file:./dev.db"
PORT=8787
# Comma-separated allowlist of browser origins; "*" in dev.
ALLOWED_ORIGIN="*"
# Device provider: simulated (default, no creds) | corellium | geelark
PROVIDER="simulated"

# --- PROD (set on Railway; do NOT use SQLite in prod) ---
# DATABASE_URL="postgresql://user:pass@host:5432/db"   # + switch schema.prisma provider to "postgresql"
# ALLOWED_ORIGIN="https://phone-farm-app.vercel.app"
# CORELLIUM_API_TOKEN="..."      # when PROVIDER=corellium
# CORELLIUM_PROJECT_ID="..."
# GEELARK_APP_ID="..."           # when PROVIDER=geelark (Android)
# GEELARK_API_KEY="..."
