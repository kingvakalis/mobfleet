# Local dev (SQLite file, zero external infra)
DATABASE_URL="file:./dev.db"
PORT=8787
# Comma-separated allowlist of browser origins; "*" in dev.
ALLOWED_ORIGIN="*"
# Device provider: simulated (default, no creds) | corellium | geelark
PROVIDER="simulated"

# --- Auth / multi-tenancy ---
# AUTH_PROVIDER: how the JWT the browser sends is verified.
#   dev      → INSECURE decode-only (NO signature check). Local dev only; forbidden in prod.
#   supabase → HS256, verified with SUPABASE_JWT_SECRET (Supabase: Project Settings → API → JWT Secret)
AUTH_PROVIDER="dev"
# AUTH_PROVIDER=dev verifies NO signature, so it must be explicitly opted into
# (local dev only — the server refuses to start with dev otherwise, and dev is
# always forbidden when NODE_ENV=production):
ALLOW_INSECURE_DEV_AUTH="1"
# SUPABASE_JWT_SECRET="<supabase jwt secret>" # required when AUTH_PROVIDER=supabase
# AUTH_AUDIENCE="authenticated"               # optional aud check (Supabase tokens use "authenticated")
# AUTH_ISSUER="https://<project>.supabase.co/auth/v1"  # optional iss check
# Public web app URL — used to build invite-accept links emailed to invitees.
APP_URL="http://localhost:5173"
# INVITE_TTL_MS=604800000                     # invite validity window (default 7 days)
# AUTO_PROVISION_TEAM=true                    # first login with no team creates a personal workspace
# Invite email transport (optional): leave unset to log accept links to the console.
# MAIL_TRANSPORT="console"                    # console | resend
# RESEND_API_KEY="re_..."                     # when MAIL_TRANSPORT=resend
# MAIL_FROM="MobFleet <invites@yourdomain.com>"

# --- PROD (set on Railway; do NOT use SQLite in prod) ---
# NODE_ENV="production"
# DATABASE_URL="postgresql://user:pass@host:5432/db"   # build/start use schema.postgres.prisma
# ALLOWED_ORIGIN="https://phone-farm-app.vercel.app"
# CORELLIUM_API_TOKEN="..."      # when PROVIDER=corellium
# CORELLIUM_PROJECT_ID="..."
# GEELARK_APP_ID="..."           # when PROVIDER=geelark (Android)
# GEELARK_API_KEY="..."
