// PRODUCTION schema (Railway/managed Postgres). Models are IDENTICAL to
// schema.prisma — keep the two in lock-step (only the header comment differs).
// This is the SOURCE schema for committed migrations; production applies them with
// `prisma migrate deploy` (Step 3 onward — see prisma/migrations/). The legacy
// `prisma db push` start path is being retired in favour of versioned migrations.
//
// MULTI-TENANCY: every tenant is a Team. Users authenticate via an external
// identity provider (Clerk / Supabase — see src/auth) and join teams through
// Membership (which carries the role). EVERY fleet row carries teamId and is
// keyed compositely by [teamId, …] so two teams can never collide and so a
// query that forgets the teamId filter cannot silently read another tenant.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy & identity ──────────────────────────────────────────────────────

model Team {
  id            String               @id
  name          String
  createdAt     Float
  // Provenance for the Supabase→Prisma migration (Step 3): the source Supabase
  // teams.id (a bare uuid). Set ONLY on migrated teams — null for native/auto-
  // provisioned teams. Unique so a Supabase team maps to exactly one Prisma team
  // and the migration is idempotent (the disjoint id spaces never cross-key).
  supabaseTeamId String?             @unique
  // Reversible artifact archival: migrated-away auto-provision artifacts are marked
  // (epoch ms) rather than deleted at cutover; membership resolution ignores
  // archived teams. Null = active.
  archivedAt    Float?
  // Team-wide transactional email preferences — which emails the workspace sends
  // (the shared EmailPreferences contract in src/lib/email/preferences.ts:
  // teamInvitesEnabled / passwordResetEnabled / welcomeEmailEnabled). Null = every
  // transactional email enabled (the defaults). Stored on Team (not on
  // TeamEmailSettings) so preferences work even when a team has no custom Resend
  // sender row and falls back to the env mailer config. NEVER store secrets here.
  notificationPrefs Json?
  memberships   Membership[]
  invites       Invite[]
  devices       Device[]
  jobs          Job[]
  proxies       Proxy[]
  automations   Automation[]
  pairingTokens DevicePairingToken[]
  apiKeys       DeviceApiKey[]
  auditLogs      AuditLog[]
  agentCommands  AgentCommand[]
  emailSettings  TeamEmailSettings?
  deviceSessions DeviceSession[]
}

model User {
  id             String       @id
  // Stable subject from the auth provider's JWT (Clerk/Supabase user id).
  authProviderId String       @unique
  email          String       @unique
  name           String?
  createdAt      Float
  memberships    Membership[]
  sentInvites    Invite[]     @relation("InviteInvitedBy")
}

model Membership {
  id          String @id
  userId      String
  teamId      String
  role        String // owner | admin | manager | operator | viewer
  // Suspension: a suspended member keeps the row (history) but loses ALL access
  // server-side (resolveAuthContext refuses to build a context for them).
  status      String @default("active") // active | suspended
  // Per-member resource scope (defaults to whole workspace). Enforced server-side
  // for device reads + commands via the shared effective-access engine.
  scopeType   String @default("workspace") // workspace | assigned_groups | assigned_phones | self
  scopeGroups Json? // string[] of group names (for assigned_groups)
  scopePhones Json? // string[] of phone ids/names (for assigned_phones)
  // Per-permission overrides layered on the role: { [permissionKey]: 'allow' | 'deny' }
  // (a key absent = inherit from the role). Same shape the authorization engine reads.
  overrides   Json?
  createdAt   Float
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

// Append-only authorization/audit trail (role changes, suspensions, removals,
// sensitive reveals, denied attempts). Never store secrets here.
model AuditLog {
  id        String  @id
  teamId    String
  actorId   String
  action    String
  target    String?
  result    String
  detail    String?
  createdAt Float
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([teamId, createdAt])
}

model Invite {
  id              String  @id
  teamId          String
  email           String
  role            String
  token           String  @unique
  status          String // pending | accepted | revoked | expired
  // Nullable: migrated Supabase invites may have a null `invited_by` (the inviter
  // was deleted / never recorded). Map those to null rather than a wrong user — no
  // false audit attribution. App-created invites always set it.
  invitedByUserId String?
  createdAt       Float
  expiresAt       Float
  acceptedAt      Float?
  team            Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy       User?   @relation("InviteInvitedBy", fields: [invitedByUserId], references: [id])

  @@index([teamId])
  @@index([email])
}

// ─── Fleet (all tenant-scoped) ───────────────────────────────────────────────

model Device {
  id            String  @default("")
  teamId        String
  name          String
  status        String
  region        String
  osVersion     String
  model         String
  proxy         String
  battery       Int
  group         String
  assignedUser  String?
  jobId         String?
  createdAt     Float
  // Infra identity + live heartbeat telemetry (mirror src/shared/types.ts).
  // Nullable: populated by the seed / device-agent heartbeats over the WS feed.
  udid          String?
  platform      String?
  ipAddress     String?
  wdaPort       Int?
  lastHeartbeat Float?
  cpuUsage      Float?
  memoryUsage   Float?
  team          Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, id])
  @@index([teamId])
}

model Job {
  id         String  @default("")
  teamId     String
  deviceId   String?
  type       String
  status     String
  progress   Float
  createdAt  Float
  startedAt  Float?
  finishedAt Float?
  error      String?
  // Run configuration (mirrors src/shared/types.ts Job.config / Supabase
  // automation_jobs.config). Nullable: simulator-created jobs omit it.
  config     Json?
  team       Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, id])
  @@index([teamId])
}

model Proxy {
  ip         String
  teamId     String
  region     String
  provider   String
  assignedTo String?
  status     String
  latency    Int
  lastCheck  Float
  team       Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, ip])
  @@index([teamId])
}

model Automation {
  id          String @default("")
  teamId      String
  name        String
  description String
  taskType    String
  successRate Float
  runs        Int
  lastRun     String
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, id])
  @@index([teamId])
}

// ─── Device provisioning (pairing tokens + per-device API keys) ───────────────

// A short-lived, single-use token minted when a user clicks "Add Device". The
// device scans the QR (containing this token), then POSTs /v1/devices/claim to
// exchange it for a real device + an API key. Tenant-scoped via teamId.
model DevicePairingToken {
  token             String  @id // UUID, embedded in the QR
  teamId            String
  createdAt         Float
  expiresAt         Float
  claimedByDeviceId String? // set once claimed → token can't be reused
  team              Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// A long-lived credential returned (once, in plaintext) on claim; only the
// SHA-256 hash is stored. The device authenticates its heartbeat WebSocket with
// it (/ws?deviceKey=…). deviceId is a plain string (no FK) so it can be created
// alongside a device that is still being written through the in-memory store.
model DeviceApiKey {
  id         String @id
  teamId     String
  deviceId   String
  keyHash    String @unique
  createdAt  Float
  lastUsedAt Float?
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([deviceId])
}

// ─── Agent command channel ───────────────────────────────────────────────────
// A command queued for a device's agent (the "agent" IS the device — one daemon
// manages many devices, each with its own DeviceApiKey). A dashboard user with
// the right permission queues a command (POST /v1/agent/command); the agent
// receives it either by an instant push over its live heartbeat WS or by polling
// GET /v1/agent/command/queue/:deviceId, then ACKs the result. deviceId is a
// plain string (matches DeviceApiKey.deviceId; no FK to Device for the same
// in-memory-store reason). `command` (action + payload) is stored as JSON.
model AgentCommand {
  id          String  @default("")
  teamId      String
  deviceId    String
  action      String // screenshot | tap | swipe | type | home | lock | unlock | launch | install | reboot
  payload     Json?
  status      String  @default("pending") // pending | delivered | acked | failed
  error       String? // failure detail reported by the agent (no secrets)
  result      Json? // validated CommandResultBody from the agent's ack (no secrets/keys)
  issuedBy    String? // user id that queued it (audit)
  createdAt   Float
  deliveredAt Float?
  ackedAt     Float?
  expiresAt   Float?
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, id])
  @@index([teamId, deviceId, status])
}

// ─── Per-team transactional email sender config (Resend) ─────────────────────
// One row per team (teamId unique). SECURITY: resendApiKey is stored as a PLAIN
// string — this codebase has no reversible-encryption helper yet (only one-way
// SHA-256 hashing for device API keys). The key is NEVER returned to the client
// (GET exposes only the last 4 chars), never logged, never put in errors. When
// absent, the mailer falls back to the MAIL_* / RESEND_API_KEY environment vars.
model TeamEmailSettings {
  id           String @id
  teamId       String @unique
  senderEmail  String
  senderName   String
  resendApiKey String
  updatedAt    Float
  team         Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ─── Device-agent connection sessions ────────────────────────────────────────
// One row per authenticated device-agent WebSocket connection: opened on the
// /ws?deviceKey=… auth path, closed (endedAt set) when that exact socket
// disconnects. `deviceId` is a plain string with NO FK to Device — matching
// DeviceApiKey/AgentCommand (Device's PK is composite [teamId, id] and its rows
// live in the in-memory store). Team-scoped (cascade) for tenant isolation.
model DeviceSession {
  id           String  @id
  teamId       String
  deviceId     String
  startedAt    Float
  endedAt      Float?
  agentVersion String?
  team         Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([deviceId, startedAt])
  @@index([teamId, startedAt])
}

// ─── Migration audit (Supabase→Prisma data migration, Step 3) ────────────────
// One row per entity the migration creates / updates / archives / deletes, with the
// full before+after row state so any batch can be reverse-exported or rolled back
// deterministically. Deliberately NOT a Team relation: `prismaId` is a plain string
// so a record can reference any entity (incl. one later deleted) without a FK that
// would block cleanup. NEVER store secrets in before/after.
//
// NOTE (post-cutover, Step 3E guardrail): this table covers the MIGRATION's writes.
// Normal Prisma-authoritative app mutations (role/scope/status/invite changes) must
// emit their OWN durable before/after audit (the existing AuditLog, extended) — this
// table is not coverage for application writes.
model MigrationRecord {
  id         String  @id
  batchId    String
  entity     String // user | team | membership | invite
  action     String // create | update | delete | archive
  supabaseId String? // source uuid (when applicable)
  prismaId   String? // target Prisma id (when applicable)
  before     Json? // full row state before the action (null for create)
  after      Json? // full row state after the action (null for delete)
  status     String  @default("ok") // ok | error
  error      String? // failure detail (NO secrets)
  createdAt  Float

  @@index([batchId])
  @@index([entity, prismaId])
}
